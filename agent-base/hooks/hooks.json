[
  {
    "matcher": "tool == \"Edit\" && tool_input.file_path matches \\\"\\.(ts|tsx|js|jsx|md)\\\"",
    "hooks": [
      {
        "type": "command",
        "command": "echo '[hook] File changed: $file_path'"
      }
    ]
  },
  {
    "matcher": "tool == \"Edit\" AND file_path matches \"package.json\"",
    "hooks": [
      {
        "type": "command",
        "command": "echo '[hook] package.json changed → run sync-project'"
      }
    ]
  }
]
